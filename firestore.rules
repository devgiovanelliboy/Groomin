rules_version = '2';

// ============================================================
// Groomin — Firestore Rules (modo TESTE, plano Spark, SEM Functions)
// Projeto: groomin-952d0
//
// Papel/tenant são lidos do documento /users/{uid} via get()
// (em vez de custom claims, que exigiriam Cloud Functions/Blaze).
// Isolamento multi-tenant continua estrito: todo acesso a dados de
// um tenant exige que o usuário pertença AQUELE tenant.
//
// Bootstrap do dono (sequencial no cliente):
//   1) cria /tenants/{tid} com ownerUid == seu uid
//   2) cria /users/{uid} com role 'owner' e tenantId = tid
//   3) cria /slugs/{slug}, /subscriptions/{tid}, serviço e barbeiro iniciais
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid()      { return request.auth.uid; }
    function userPath() { return /databases/$(database)/documents/users/$(uid()); }
    function hasUser()  { return signedIn() && exists(userPath()); }
    function ud()       { return get(userPath()).data; }
    function role()     { return hasUser() ? ud().role : ''; }
    function myTenant() { return hasUser() ? (ud().tenantId != null ? ud().tenantId : ud().barbershopId) : ''; }
    function myCustomer(){ return hasUser() ? ud().customerId : ''; }
    function linkPath(tid) { return /databases/$(database)/documents/users/$(uid())/customerLinks/$(tid); }
    function hasCustomerLink(tid) { return signedIn() && exists(linkPath(tid)); }
    function customerLink(tid) { return get(linkPath(tid)).data; }
    function isSuper()  {
      return role() in ['super_admin', 'superadmin', 'admin_master']
        || (signedIn() && request.auth.token.get('isSuperAdmin', false) == true);
    }
    function inTenant(tid){ return hasUser() && (myTenant() == tid || (ud().role == 'customer' && hasCustomerLink(tid))); }
    function staffOf(tid){ return inTenant(tid) && (ud().role in ['owner','manager','receptionist','barber']); }
    function mgrOf(tid) { return inTenant(tid) && (ud().role in ['owner','manager']); }
    function ownerOf(tid){ return inTenant(tid) && ud().role == 'owner'; }
    function tenantActive(tid){ return exists(/databases/$(database)/documents/tenants/$(tid))
                                  && get(/databases/$(database)/documents/tenants/$(tid)).data.status == 'active'; }
    function publicCustomerFields(tid) {
      return (!request.resource.data.keys().hasAny(['tenantId']) || request.resource.data.tenantId == tid)
             && request.resource.data.barbershopId == tid
             && request.resource.data.name is string
             && request.resource.data.name.size() >= 2
             && request.resource.data.phone is string
             && request.resource.data.phone.size() >= 8
             // Antipoluição: o cliente só pode se cadastrar com a própria identidade
             // (e-mail do doc == e-mail da conta logada). Impede encher a lista de
             // outra barbearia com registros falsos usando uma conta qualquer.
             && request.auth.token.email != null
             && request.resource.data.email is string
             && request.resource.data.email.lower() == request.auth.token.email.lower()
             && request.resource.data.keys().hasOnly(['tenantId','barbershopId','name','phone','whatsapp','email','birthday','notes','createdAt']);
    }
    function customerOwnsDoc(tid, id) {
      return inTenant(tid)
             && role() == 'customer'
             && id == myCustomer()
             && (!resource.data.keys().hasAny(['tenantId']) || request.resource.data.tenantId == resource.data.tenantId)
             && request.resource.data.barbershopId == resource.data.barbershopId
             && request.resource.data.keys().hasOnly(['tenantId','barbershopId','name','phone','whatsapp','email','birthday','notes','createdAt'])
             && request.resource.data.name is string
             && request.resource.data.name.size() >= 2
             && request.resource.data.phone is string
             && request.resource.data.phone.size() >= 8;
    }
    function validReview(tid) {
      return request.resource.data.barbershopId == tid
             && (!request.resource.data.keys().hasAny(['tenantId']) || request.resource.data.tenantId == tid)
             && request.resource.data.customerName is string
             && request.resource.data.customerName.size() >= 2
             && request.resource.data.rating is int
             && request.resource.data.rating >= 1
             && request.resource.data.rating <= 5
             && request.resource.data.text is string
             && request.resource.data.text.size() >= 2
             && request.resource.data.text.size() <= 500
             && request.resource.data.date is string
             && request.resource.data.keys().hasOnly(['tenantId','barbershopId','customerName','rating','text','date','customerId','appointmentId','createdAt']);
    }
    function userSafeFields() {
      return request.resource.data.keys().hasOnly([
        'name','email','phone','whatsapp','address','role','tenantId','customerId','barberId','active','createdAt','updatedAt',
        'emailVerified','emailVerificationStatus','emailVerificationSkipped',
        'emailVerificationSkippedReason','emailVerificationSkippedAt'
      ]);
    }
    function validCustomerLink(tid) {
      return request.resource.data.tenantId == tid
             && request.resource.data.customerId is string
             && request.resource.data.email == request.auth.token.email
             && request.resource.data.keys().hasOnly(['tenantId','customerId','email','name','createdAt','lastUsedAt'])
             && get(/databases/$(database)/documents/tenants/$(tid)/customers/$(request.resource.data.customerId)).data.email == request.auth.token.email
             && get(/databases/$(database)/documents/tenants/$(tid)/customers/$(request.resource.data.customerId)).data.barbershopId == tid;
    }
    function userCustomerSwitchAllowed() {
      return resource.data.role == 'customer'
             && request.resource.data.role == resource.data.role
             && request.resource.data.active == resource.data.active
             && request.resource.data.tenantId is string
             && request.resource.data.customerId is string
             && exists(/databases/$(database)/documents/users/$(uid())/customerLinks/$(request.resource.data.tenantId))
             && get(/databases/$(database)/documents/users/$(uid())/customerLinks/$(request.resource.data.tenantId)).data.customerId == request.resource.data.customerId;
    }
    function customerCanCancelAppointment(tid) {
      return inTenant(tid)
             && role() == 'customer'
             && (resource.data.customerId == myCustomer()
                 || (hasCustomerLink(tid) && resource.data.customerId == customerLink(tid).customerId))
             && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
             && request.resource.data.status == 'cancelado'
             && (!request.resource.data.keys().hasAny(['updatedAt'])
                 || request.resource.data.updatedAt is number);
    }

    // ===================== USERS =====================
    match /users/{userId} {
      allow read: if isSuper()
                  || (signedIn() && uid() == userId)
                  || (hasUser() && (ud().role in ['owner','manager']) && resource.data.tenantId == myTenant());
      // self-signup do dono (role owner) ou cliente; staff é criado por gerência
      allow create: if userSafeFields() && (isSuper()
                    || (uid() == userId
                        && request.resource.data.role == 'owner'
                        && request.resource.data.tenantId is string
                        && get(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId)).data.ownerUid == uid())
                    || (uid() == userId
                        && request.resource.data.role == 'customer'
                        && request.resource.data.tenantId is string
                        && request.resource.data.customerId is string
                        && get(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId)/customers/$(request.resource.data.customerId)).data.tenantId == request.resource.data.tenantId
                        && get(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId)/customers/$(request.resource.data.customerId)).data.barbershopId == request.resource.data.tenantId
                        && get(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId)/customers/$(request.resource.data.customerId)).data.email == request.resource.data.email)
                    || (hasUser() && (ud().role in ['owner','manager'])
                        && request.resource.data.tenantId == myTenant()
                        && request.resource.data.role in ['manager','receptionist','barber']));
      allow update: if isSuper()
                    || (userSafeFields()
                        && uid() == userId
                        && (!request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['role','tenantId','active','customerId','barberId','createdAt'])
                          || (userCustomerSwitchAllowed()
                              && !request.resource.data.diff(resource.data).affectedKeys()
                                .hasAny(['role','active','barberId','createdAt']))));
      allow delete: if isSuper() || (hasUser() && mgrOf(resource.data.tenantId));

      match /customerLinks/{tid} {
        allow read: if signedIn() && uid() == userId;
        allow create, update: if signedIn()
                              && uid() == userId
                              && hasUser()
                              && role() == 'customer'
                              && validCustomerLink(tid);
        allow delete: if signedIn() && uid() == userId;
      }
    }

    // ============== SLUG REGISTRY (público p/ resolver a página) ==============
    match /slugs/{slug} {
      allow read:   if true;
      allow create: if signedIn()
                    && request.resource.data.tenantId is string
                    && get(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId)).data.ownerUid == uid();
      allow update, delete: if isSuper();
    }

    // ===================== PLATAFORMA =====================
    match /subscriptions/{tid} {
      allow read:   if isSuper() || inTenant(tid);
      // criada no bootstrap pelo dono do tenant (tenant já existe e é dele)
      allow create: if isSuper()
                    || (signedIn()
                        && get(/databases/$(database)/documents/tenants/$(tid)).data.ownerUid == uid());
      allow update: if isSuper();
      allow delete: if isSuper();
    }
    match /invoices/{id}   { allow read: if isSuper() || mgrOf(resource.data.tenantId);
                             allow write: if isSuper(); }
    match /auditLogs/{id}  { allow read:   if isSuper() || mgrOf(resource.data.tenantId);
                             allow create: if hasUser() && request.resource.data.tenantId == myTenant();
                             allow update, delete: if false; }
    match /adminActions/{id} {
      allow read, create: if isSuper();
      allow update, delete: if false;
    }
    match /platformSettings/{doc} { allow read: if true; allow write: if isSuper(); }

    // ===================== TENANTS =====================
    match /tenants/{tid} {
      allow read:   if true; // perfil público (página da barbearia)
      allow create: if isSuper() || (signedIn() && request.resource.data.ownerUid == uid());
      allow update: if isSuper()
                    || ((ownerOf(tid)
                        || (signedIn() && resource.data.ownerUid == uid()))
                        && !request.resource.data.diff(resource.data).affectedKeys()
                          .hasAny(['ownerUid', 'slug', 'planId', 'status', 'createdAt']));
      allow delete: if isSuper();

      // -------- subcoleções PÚBLICAS (necessárias p/ agendar) --------
      match /services/{id} { allow read: if true; allow write: if isSuper() || mgrOf(tid); }
      match /barbers/{id}  { allow read: if true; allow write: if isSuper() || mgrOf(tid); }
      match /reviews/{id}  { allow read: if true;
                             // Exige conta vinculada ao tenant para evitar review bombing por contas aleatórias
                             allow create: if signedIn() && tenantActive(tid) && validReview(tid)
                                           && (staffOf(tid) || inTenant(tid));
                             allow update, delete: if isSuper() || mgrOf(tid); }

      // -------- agendamentos --------
      match /appointments/{id} {
        allow read:   if isSuper() || staffOf(tid)
                      || (inTenant(tid) && role() == 'customer'
                          && (resource.data.customerId == myCustomer()
                              || (hasCustomerLink(tid) && resource.data.customerId == customerLink(tid).customerId)));
        // Booking público: confirma automaticamente usando um ID único por
        // barbearia + barbeiro + dia + horário. Se o doc já existir e não estiver
        // cancelado, a transação do cliente falha e o horário fica bloqueado.
        allow create: if isSuper() || staffOf(tid);
        allow update: if isSuper() || staffOf(tid)
                      || customerCanCancelAppointment(tid);
        allow delete: if isSuper() || mgrOf(tid);
      }

      // -------- clientes (booking público cria/encontra) --------
      match /customers/{id} {
        allow read:   if isSuper() || staffOf(tid)
                      || (inTenant(tid) && role() == 'customer'
                          && (id == myCustomer()
                              || (hasCustomerLink(tid) && id == customerLink(tid).customerId)));
        allow create: if isSuper() || staffOf(tid)
                      || (signedIn() && publicCustomerFields(tid) && tenantActive(tid));
        allow update: if isSuper() || staffOf(tid)
                      || customerOwnsDoc(tid, id);
        allow delete: if isSuper() || mgrOf(tid);
      }

      // -------- privadas do tenant --------
      match /sales/{id}        { allow read, write: if isSuper() || staffOf(tid); }
      match /cashSessions/{id} { allow read, write: if isSuper() || staffOf(tid); }
      match /stockMoves/{id}   { allow read, write: if isSuper() || staffOf(tid); }
      match /blocks/{id}       { allow read: if true; allow write: if isSuper() || staffOf(tid); }
      match /notifications/{id}{ allow read: if isSuper() || staffOf(tid);
                                 allow create: if isSuper() || staffOf(tid);
                                 allow update, delete: if isSuper() || staffOf(tid); }
      match /products/{id}   { allow read: if isSuper() || staffOf(tid); allow write: if isSuper() || mgrOf(tid); }
      match /combos/{id}     { allow read: if isSuper() || staffOf(tid); allow write: if isSuper() || mgrOf(tid); }
      match /campaigns/{id}  { allow read: if isSuper() || mgrOf(tid);   allow write: if isSuper() || mgrOf(tid); }
      match /settings/{id}   { allow read: if isSuper() || staffOf(tid); allow write: if isSuper() || ownerOf(tid); }
    }

    // ===================== DEFAULT DENY =====================
    match /{document=**} { allow read, write: if false; }
  }
}
