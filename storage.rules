rules_version = '2';

// ============================================================
// Groomin — Cloud Storage Rules (multi-tenant)
// Estrutura: /tenants/{tid}/{tipo}/{arquivo}
//   logos, capas e fotos de barbeiros/produtos.
// Leitura pública (imagens da página pública); escrita só do próprio tenant.
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn()    { return request.auth != null; }
    function userPath()    { return /databases/(default)/documents/users/$(request.auth.uid); }
    function hasUser()     { return signedIn() && firestore.exists(userPath()); }
    function ud()          { return firestore.get(userPath()).data; }
    function role()        { return hasUser() ? ud().role : ''; }
    function tenant()      { return hasUser() ? ud().tenantId : ''; }
    function isSuper()     { return signedIn() && role() == 'super_admin'; }
    function mgrOf(tid)    { return signedIn() && tenant() == tid && (role() in ['owner','manager']); }
    // valida imagem e tamanho (<= 5MB)
    function validImage()  { return request.resource.size < 5 * 1024 * 1024
                                 && request.resource.contentType.matches('image/.*'); }

    match /tenants/{tid}/{kind}/{fileName} {
      allow read:  if true;                          // imagens públicas
      allow create, update: if (kind in ['logos', 'covers', 'barbers', 'products'])
                            && (isSuper() || mgrOf(tid)) && validImage();
      allow delete: if isSuper() || mgrOf(tid);
    }

    // tudo o mais negado
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
