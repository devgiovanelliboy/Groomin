{
  "hosting": {
    "site": "groomin-bio",
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase.instagram.json",
      "**/.*",
      ".git/**",
      ".claude/**",
      ".firebase/**",
      "**/node_modules/**",
      "functions/**",
      "test-results/**",
      "*.rules",
      "firestore.indexes.json",
      "*.md",
      "README*"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      { "source": "**", "destination": "/instagram.html" }
    ],
    "headers": [
      {
        "glob": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      }
    ]
  }
}
